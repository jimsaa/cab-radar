# Supabase — Dashboard → Settings → API → Project URL (NOT a custom domain)
# Must look like: https://abcdefghijklmnopqrst.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# New publishable key (sb_publishable_...) or legacy anon key (eyJ...)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only — secret key (sb_secret_...) or legacy service_role (eyJ...)
SUPABASE_SECRET_KEY=

# Server-only — HMAC key for taxi licence hashing (must match migration pepper)
LICENCE_HASH_SECRET=

# Web Push (generate with: npx web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@cabrader.app

# Optional: Google Geocoding API for reverse geocode (falls back to Nominatim)
GOOGLE_GEOCODING_API_KEY=

# Stripe (årsmedlemskap 199 kr)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Monthly membership reset cron (Bearer token)
CRON_SECRET=

# Coming soon / private beta (set true on cabradar.se before public launch)
COMING_SOON_ENABLED=false

# Beta gate password for "Beta-inloggning" (server-only)
BETA_GATE_PASSWORD=7878
